# Copia este archivo como .env y ajusta los valores
SECRET_KEY=cambia-esta-clave-en-produccion
DEBUG=True

# Hosts y orígenes permitidos (separados por coma). Requeridos en producción.
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=
# En producción (DEBUG=False) puedes ajustar:
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000

# Base de datos PostgreSQL
DB_NAME=stockly
DB_USER=stockly
DB_PASSWORD=stockly_dev_password
DB_HOST=localhost
DB_PORT=5433

# Correo (Gmail SMTP con contraseña de aplicación)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tucorreo@gmail.com
EMAIL_HOST_PASSWORD=tu_contrasena_de_aplicacion
DEFAULT_FROM_EMAIL=Stockly <tucorreo@gmail.com>

# URL del frontend para construir los enlaces de los correos
FRONTEND_URL=http://localhost:5173
